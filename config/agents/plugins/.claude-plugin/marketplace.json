{
	"$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
	"name": "dotfiles",
	"description": "Local plugins managed from the dotfiles repository",
	"owner": {
		"name": "Rafa Gómez"
	},
	"plugins": [
		{
			"name": "tsgo-lsp",
			"description": "TypeScript/JavaScript code intelligence via the TypeScript 7 native compiler LSP, much faster than tsserver on large monorepos",
			"version": "1.1.0",
			"source": "./tsgo-lsp",
			"category": "development",
			"strict": false,
			"lspServers": {
				"tsgo": {
					"command": "tsc",
					"args": ["--lsp", "-stdio"],
					"extensionToLanguage": {
						".ts": "typescript",
						".tsx": "typescriptreact",
						".js": "javascript",
						".jsx": "javascriptreact",
						".mts": "typescript",
						".cts": "typescript",
						".mjs": "javascript",
						".cjs": "javascript"
					}
				}
			}
		}
	]
}
