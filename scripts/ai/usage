#!/usr/bin/env bash

set -euo pipefail

source "$DOTLY_PATH/scripts/core/_main.sh"

##? List Claude Code and Codex sessions with their cost, activity and directory
#?? 3.2.0
##?
##? By default only the last 7 days of sessions are shown; pass --all to list every session.
##?
##? Usage:
##?   usage [--all]
##?   usage -h | --help
docs::parse "$@"

claude_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
codex_dir="${CODEX_HOME:-$HOME/.codex}"

format_date='sub("\\.[0-9]+"; "") | fromdateiso8601 | strflocaltime("%Y-%m-%d %H:%M:%S")'

format_duration() {
	local s="$1" h m
	h=$((s / 3600))
	m=$(((s % 3600) / 60))
	s=$((s % 60))

	if ((h > 0)); then
		printf '%dh%02dm' "$h" "$m"
	elif ((m > 0)); then
		printf '%dm%02ds' "$m" "$s"
	else
		printf '%ds' "$s"
	fi
}

session_duration() {
	local transcript="$1" secs

	[[ -z $transcript || ! -f $transcript ]] && {
		printf -- '-'
		return
	}

	secs="$(
		jq -rs '
			[
				.[]
				| select((.type == "system" and .subtype == "away_summary") | not)
				| .timestamp? // empty
				| sub("\\.[0-9]+"; "") | fromdateiso8601
			] as $t
			| if ($t | length) < 2 then empty else (($t | max) - ($t | min)) end
		' "$transcript" 2>/dev/null
	)"

	[[ -z $secs ]] && {
		printf -- '-'
		return
	}
	format_duration "$secs"
}

emit_claude_rows() {
	command ccusage claude session --json 2>/dev/null |
		jq -r "
			.sessions[]
			| [
				.sessionId,
				(.totalCost | tostring),
				(.lastActivity | $format_date)
			]
			| @tsv
		" |
		while IFS=$'\t' read -r session_id cost last_activity; do
			transcript="$(
				find "$claude_dir/projects" \
					-type f \
					-name "${session_id}.jsonl" \
					-print \
					-quit 2>/dev/null
			)"

			if [[ -n $transcript ]]; then
				cwd="$(
					jq -r 'select(.cwd? | type == "string") | .cwd' \
						"$transcript" 2>/dev/null | tail -n 1
				)"
				[[ -z $cwd ]] && cwd="$(dirname "$transcript")"

				title="$(
					jq -r 'select(.aiTitle? | type == "string") | .aiTitle' \
						"$transcript" 2>/dev/null | tail -n 1
				)"

				model="$(
					jq -r 'select(.type == "assistant") | .message.model // empty' \
						"$transcript" 2>/dev/null |
						sort | uniq -c | sort -rn | head -n 1 | awk '{print $2}'
				)"
				model="${model#claude-}"
			else
				cwd="<not found>"
			fi

			duration="$(session_duration "$transcript")"

			print_row "$last_activity" "cc" "${model:-}" "-" "$duration" "$cost" "${title:-}" "$cwd"
		done
}

emit_codex_rows() {
	command ccusage codex session --json 2>/dev/null |
		jq -r "
			.sessions[]
			| [
				.sessionFile,
				(.costUSD | tostring),
				(.lastActivity | $format_date)
			]
			| @tsv
		" |
		while IFS=$'\t' read -r session_file cost last_activity; do
			transcript="$(
				find "$codex_dir" \
					-type f \
					-name "${session_file}.jsonl" \
					-print \
					-quit 2>/dev/null
			)"

			if [[ -n $transcript ]]; then
				cwd="$(
					jq -r 'select(.type == "session_meta") | .payload.cwd' \
						"$transcript" 2>/dev/null | head -n 1
				)"
				[[ -z $cwd ]] && cwd="<unknown>"

				title="$(
					jq -r '
						select(.type == "event_msg" and .payload.type == "user_message")
						| .payload.message
					' "$transcript" 2>/dev/null | head -n 1
				)"

				model="$(
					jq -r 'select(.type == "turn_context") | .payload.model // empty' \
						"$transcript" 2>/dev/null | tail -n 1
				)"
				effort="$(
					jq -r 'select(.type == "turn_context") | .payload.effort // empty' \
						"$transcript" 2>/dev/null | tail -n 1
				)"
			else
				cwd="<not found>"
			fi

			duration="$(session_duration "$transcript")"

			print_row "$last_activity" "codex" "${model:-}" "${effort:-}" "$duration" "$cost" "${title:-}" "$cwd"
		done
}

print_row() {
	local last_activity="$1" harness="$2" model="$3" effort="$4" duration="$5" cost="$6" title="$7" cwd="$8"

	title="$(printf '%s' "$title" | tr '\t\n' '  ')"
	[[ -z $title ]] && title="<untitled>"
	((${#title} > 70)) && title="${title:0:69}…"

	[[ $cwd == "$HOME"* ]] && cwd="~${cwd#"$HOME"}"

	printf '%s\t%s\t%s\t%s\t%s\t$%.2f\t%s\t%s\n' \
		"$last_activity" "$harness" "${model:-<unknown>}" "${effort:--}" "${duration:--}" "$cost" "$title" "$cwd"
}

rows="$(
	{
		emit_claude_rows
		emit_codex_rows
	} | sort -t $'\t' -k1,1 -r
)"

if [[ $all == "false" ]]; then
	cutoff="$(date -d '7 days ago' +%F 2>/dev/null || date -v-7d +%F)"
	rows="$(
		printf '%s\n' "$rows" |
			awk -F'\t' -v cutoff="$cutoff" 'substr($1, 1, 10) >= cutoff'
	)"
fi

{
	printf 'LAST ACTIVITY\tHARNESS\tMODEL\tEFFORT\tDURATION\tCOST\tTITLE\tPROJECT\n'
	[[ -n $rows ]] && printf '%s\n' "$rows"
} | column -t -s $'\t'
