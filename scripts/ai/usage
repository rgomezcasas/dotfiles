#!/usr/bin/env bash

set -euo pipefail

source "$DOTLY_PATH/scripts/core/_main.sh"

##? List Claude Code and Codex sessions with their cost, activity and directory
#?? 3.0.0
##?
##? By default only today's sessions are shown; pass --all to list every session.
##?
##? Usage:
##?   usage [--all]
##?   usage -h | --help
docs::parse "$@"

claude_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
codex_dir="${CODEX_HOME:-$HOME/.codex}"

format_date='sub("\\.[0-9]+"; "") | fromdateiso8601 | strflocaltime("%Y-%m-%d %H:%M:%S")'

emit_claude_rows() {
	command ccusage claude session --json 2>/dev/null |
		jq -r "
			.sessions[]
			| [
				.sessionId,
				(.totalCost | tostring),
				(.lastActivity | $format_date)
			]
			| @tsv
		" |
		while IFS=$'\t' read -r session_id cost last_activity; do
			transcript="$(
				find "$claude_dir/projects" \
					-type f \
					-name "${session_id}.jsonl" \
					-print \
					-quit 2>/dev/null
			)"

			if [[ -n "$transcript" ]]; then
				cwd="$(
					jq -r 'select(.cwd? | type == "string") | .cwd' \
						"$transcript" 2>/dev/null | tail -n 1
				)"
				[[ -z "$cwd" ]] && cwd="$(dirname "$transcript")"

				title="$(
					jq -r 'select(.aiTitle? | type == "string") | .aiTitle' \
						"$transcript" 2>/dev/null | tail -n 1
				)"

				model="$(
					jq -r 'select(.type == "assistant") | .message.model // empty' \
						"$transcript" 2>/dev/null |
						sort | uniq -c | sort -rn | head -n 1 | awk '{print $2}'
				)"
				model="${model#claude-}"
			else
				cwd="<not found>"
			fi

			print_row "$last_activity" "cc" "${model:-}" "-" "$cost" "${title:-}" "$cwd"
		done
}

emit_codex_rows() {
	command ccusage codex session --json 2>/dev/null |
		jq -r "
			.sessions[]
			| [
				.sessionFile,
				(.costUSD | tostring),
				(.lastActivity | $format_date)
			]
			| @tsv
		" |
		while IFS=$'\t' read -r session_file cost last_activity; do
			transcript="$(
				find "$codex_dir" \
					-type f \
					-name "${session_file}.jsonl" \
					-print \
					-quit 2>/dev/null
			)"

			if [[ -n "$transcript" ]]; then
				cwd="$(
					jq -r 'select(.type == "session_meta") | .payload.cwd' \
						"$transcript" 2>/dev/null | head -n 1
				)"
				[[ -z "$cwd" ]] && cwd="<unknown>"

				title="$(
					jq -r '
						select(.type == "event_msg" and .payload.type == "user_message")
						| .payload.message
					' "$transcript" 2>/dev/null | head -n 1
				)"

				model="$(
					jq -r 'select(.type == "turn_context") | .payload.model // empty' \
						"$transcript" 2>/dev/null | tail -n 1
				)"
				effort="$(
					jq -r 'select(.type == "turn_context") | .payload.effort // empty' \
						"$transcript" 2>/dev/null | tail -n 1
				)"
			else
				cwd="<not found>"
			fi

			print_row "$last_activity" "codex" "${model:-}" "${effort:-}" "$cost" "${title:-}" "$cwd"
		done
}

print_row() {
	local last_activity="$1" harness="$2" model="$3" effort="$4" cost="$5" title="$6" cwd="$7"

	title="$(printf '%s' "$title" | tr '\t\n' '  ')"
	[[ -z "$title" ]] && title="<untitled>"
	(( ${#title} > 70 )) && title="${title:0:69}…"

	printf '%s\t%s\t%s\t%s\t$%.4f\t%s\t%s\n' \
		"$last_activity" "$harness" "${model:-<unknown>}" "${effort:--}" "$cost" "$title" "$cwd"
}

rows="$(
	{
		emit_claude_rows
		emit_codex_rows
	} | sort -t $'\t' -k1,1 -r
)"

if [[ "$all" == "false" ]]; then
	rows="$(
		printf '%s\n' "$rows" |
			awk -F'\t' -v today="$(date +%F)" 'substr($1, 1, 10) == today'
	)"
fi

{
	printf 'LAST ACTIVITY\tHARNESS\tMODEL\tEFFORT\tCOST\tTITLE\tPROJECT\n'
	[[ -n "$rows" ]] && printf '%s\n' "$rows"
} | column -t -s $'\t'
