#!/usr/bin/env bash

set -euo pipefail

source "$DOTLY_PATH/scripts/core/_main.sh"

##? Clear all Docker containers and volumes
##?
##? Usage:
##?   clear
##?   clear -h | --help

docs::parse "$@"

echo "🐳 Stopping all running containers..."
docker ps -aq | xargs docker stop 2>/dev/null || echo "No containers to stop"

echo "🗑️  Removing all containers..."
docker ps -aq | xargs docker rm 2>/dev/null || echo "No containers to remove"

echo "💾 Removing all volumes..."
docker volume ls -q | xargs docker volume rm 2>/dev/null || echo "No volumes to remove"

echo "✅ Docker cleanup complete!"
